# Local mode works without credentials.
PORT=4180
HOST=127.0.0.1

# CockroachDB Cloud connection string. Required for cloud persistence.
DATABASE_URL=

# AWS Bedrock is optional locally and required for the cloud adjudicator.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=

# Leave false in production. Allows the dashboard reset button to truncate demo data.
ALLOW_DEMO_RESET=false
